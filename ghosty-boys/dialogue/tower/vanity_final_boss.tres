[gd_resource type="Resource" script_class="DialogueConversation" format=3 uid="uid://qyishnb2yps0"]

[ext_resource type="Script" uid="uid://dvr4dfli4tbxn" path="res://battle/classes/dialogue_line.gd" id="1_88qco"]
[ext_resource type="Script" uid="uid://crsnq2fq76xma" path="res://battle/classes/dialogue_conversation.gd" id="2_kxght"]
[ext_resource type="Texture2D" uid="uid://c0gtkx2ic8hyf" path="res://art/portraits/demon_boss_lady_portrait.png" id="2_m26jy"]
[ext_resource type="Texture2D" uid="uid://85bxmm11fx8a" path="res://art/portraits/jackal_portrait.png" id="3_n3xdn"]
[ext_resource type="Texture2D" uid="uid://c0nwmag75d5b4" path="res://art/portraits/mel_portrait.png" id="4_xb6yp"]
[ext_resource type="Texture2D" uid="uid://ba4r0h2itoay6" path="res://art/portraits/daisy_portrait.png" id="5_m87p2"]

[sub_resource type="Resource" id="Resource_m4whk"]
script = ExtResource("1_88qco")
speaker_name = "Vanity"
portrait = ExtResource("2_m26jy")
text = "There you are. The ones making a mess of my tower, and my town."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_m26jy"]
script = ExtResource("1_88qco")
speaker_name = "Jackal"
portrait = ExtResource("3_n3xdn")
text = "Oh boy."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_c4igj"]
script = ExtResource("1_88qco")
speaker_name = "Mel"
portrait = ExtResource("4_xb6yp")
text = "This is NOT your town."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_n3xdn"]
script = ExtResource("1_88qco")
speaker_name = "Vanity"
portrait = ExtResource("2_m26jy")
text = "Oh, but you're wrong about that, darling."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_xb6yp"]
script = ExtResource("1_88qco")
speaker_name = "Vanity"
portrait = ExtResource("2_m26jy")
text = "A small town so far from any real civilization that no one notices their sudden, mass silence is perfect for me."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_m87p2"]
script = ExtResource("1_88qco")
speaker_name = "Vanity"
portrait = ExtResource("2_m26jy")
text = "I've been enjoying my feast, but then I felt some creatures disturbing my peace in the town."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_rdccn"]
script = ExtResource("1_88qco")
speaker_name = "Jackal"
portrait = ExtResource("3_n3xdn")
text = "You've got a hell of an idea of peace, lady."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_53260"]
script = ExtResource("1_88qco")
speaker_name = "Vanity"
portrait = ExtResource("2_m26jy")
text = "Hm... As a fellow demon, I thought you'd understand."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_ejxj2"]
script = ExtResource("1_88qco")
speaker_name = "Jackal"
portrait = ExtResource("3_n3xdn")
text = "I am nothing like you."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_48vxf"]
script = ExtResource("1_88qco")
speaker_name = "Daisy"
portrait = ExtResource("5_m87p2")
text = "You... You need to let the people in this town go!"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_v6xdq"]
script = ExtResource("1_88qco")
speaker_name = "Mel"
portrait = ExtResource("4_xb6yp")
text = "And if you don't, then we're going to make you."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_tnbcg"]
script = ExtResource("1_88qco")
speaker_name = "Vanity"
portrait = ExtResource("2_m26jy")
text = "Then let's dance, little darlings."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[resource]
script = ExtResource("2_kxght")
lines = Array[ExtResource("1_88qco")]([SubResource("Resource_m4whk"), SubResource("Resource_m26jy"), SubResource("Resource_c4igj"), SubResource("Resource_n3xdn"), SubResource("Resource_xb6yp"), SubResource("Resource_m87p2"), SubResource("Resource_rdccn"), SubResource("Resource_53260"), SubResource("Resource_ejxj2"), SubResource("Resource_48vxf"), SubResource("Resource_v6xdq"), SubResource("Resource_tnbcg")])
