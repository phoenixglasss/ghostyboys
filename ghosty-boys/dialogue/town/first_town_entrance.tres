[sub_resource type="Resource" id="Resource_dxgey"]
script = ExtResource("1_4vlkn")
speaker_name = "Daisy"
portrait = ExtResource("2_7lh4s")
text = "I can hear those... things. Sounds like a lot of them."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_7lh4s"]
script = ExtResource("1_4vlkn")
speaker_name = "Jackal"
portrait = ExtResource("3_kwf3b")
text = "The sounds of the night are so beautiful, aren't they? The wind, the groans of the damned, crickets..."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_kwf3b"]
script = ExtResource("1_4vlkn")
speaker_name = "Mel"
portrait = ExtResource("4_qwswg")
text = "I see some kind of office building over there. Let's go check for survivors."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_qwswg"]
script = ExtResource("1_4vlkn")
speaker_name = "Mel"
portrait = ExtResource("4_qwswg")
text = "Keep your eyes peeled. We may have to fight our way there."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_omsj2"]
script = ExtResource("1_4vlkn")
speaker_name = "Jackal"
portrait = ExtResource("3_kwf3b")
text = "My eyes are always peeled! Benefits of not having eyelids. Or skin."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_y6m75"]
script = ExtResource("1_4vlkn")
speaker_name = "Mel"
portrait = ExtResource("4_qwswg")
text = "Focus."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_b4bkw"]
script = ExtResource("1_4vlkn")
speaker_name = "Daisy"
portrait = ExtResource("2_7lh4s")
text = "...huh. You really don't have eyelids."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_bdjse"]
script = ExtResource("1_4vlkn")
speaker_name = "Mel"
portrait = ExtResource("4_qwswg")
text = "FOCUS, YOU TWO."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

