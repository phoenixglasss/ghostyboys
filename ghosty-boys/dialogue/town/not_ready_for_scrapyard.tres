[ext_resource type="Texture2D" uid="uid://ba4r0h2itoay6" path="res://art/portraits/daisy_portrait.png" id="2_u8lc1"]
[ext_resource type="Texture2D" uid="uid://85bxmm11fx8a" path="res://art/portraits/jackal_portrait.png" id="3_upfr8"]
[ext_resource type="Texture2D" uid="uid://cp1ux7waje02m" path="res://art/portraits/bodyguard_2_portrait.png" id="4_fb4o4"]
[ext_resource type="Texture2D" uid="uid://c0nwmag75d5b4" path="res://art/portraits/mel_portrait.png" id="5_oc72i"]
[ext_resource type="Texture2D" uid="uid://dvs8wgs0fa4te" path="res://art/portraits/bodyguard_1_portrait.png" id="6_rb4ec"]
[ext_resource type="Script" uid="uid://crsnq2fq76xma" path="res://battle/classes/dialogue_conversation.gd" id="7_myig4"]

[sub_resource type="Resource" id="Resource_qpc6n"]
script = ExtResource("1_k8vht")
speaker_name = "Daisy"
portrait = ExtResource("2_u8lc1")
text = "Hello? Is anyone in there? We, uh, would like to come in... Please."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_1q0ge"]
script = ExtResource("1_k8vht")
speaker_name = "Jackal"
portrait = ExtResource("3_upfr8")
text = "And they say kids don't know their manners these days."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_nqrvh"]
script = ExtResource("1_k8vht")
speaker_name = "????"
portrait = ExtResource("4_fb4o4")
text = "Buzz off."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_xg2u0"]
script = ExtResource("1_k8vht")
speaker_name = "Mel"
portrait = ExtResource("5_oc72i")
text = "We're just trying to pass through. We've got no issues with you."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_c3khn"]
script = ExtResource("1_k8vht")
speaker_name = "Also ????"
portrait = ExtResource("6_rb4ec")
text = "Maybe WE got issues with YOU!"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_8ptgw"]
script = ExtResource("1_k8vht")
speaker_name = "Jackal"
portrait = ExtResource("3_upfr8")
text = "Lovely. Why don't you unlock the gate and we can hash out our issues together? Civilized-like."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_eeaw2"]
script = ExtResource("1_k8vht")
speaker_name = "????"
portrait = ExtResource("4_fb4o4")
text = "Can't do that. Boss said no one comes through. Says he's gotta protect his lady love."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_37t3c"]
script = ExtResource("1_k8vht")
speaker_name = "Daisy"
portrait = ExtResource("5_oc72i")
text = "...what?"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_o6dma"]
script = ExtResource("1_k8vht")
speaker_name = "????"
portrait = ExtResource("6_rb4ec")
text = "You know! The crazy red chick with horns up in the tower! Boss says he's gotta keep her safe."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_4g6bb"]
script = ExtResource("1_k8vht")
speaker_name = "????"
portrait = ExtResource("4_fb4o4")
text = "Shut up! You're telling 'em too much!"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_ehtl8"]
script = ExtResource("1_k8vht")
speaker_name = "????"
portrait = ExtResource("6_rb4ec")
text = "You're the one who started talking about the boss man's lady love!"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_x5pxl"]
script = ExtResource("1_k8vht")
speaker_name = "Jackal"
portrait = ExtResource("3_upfr8")
text = "I fear we will get nowhere with these two strapping philosophers. "
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_1cony"]
script = ExtResource("1_k8vht")
speaker_name = "Mel"
portrait = ExtResource("5_oc72i")
text = "I wonder who this \"boss\" is that they're talking about. I bet someone around here knows something about him."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_v5phh"]
script = ExtResource("1_k8vht")
speaker_name = "Daisy"
portrait = ExtResource("2_u8lc1")
text = "There was another building back by the bar... Looked like it had some lights on inside. Maybe we could check it out?"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_3kcat"]
script = ExtResource("1_k8vht")
speaker_name = "Jackal"
portrait = ExtResource("3_upfr8")
text = "As much as I hate to miss the rest of the riveting argument between these two, let's head on over."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

