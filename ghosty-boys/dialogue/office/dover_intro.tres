[gd_resource type="Resource" script_class="DialogueConversation" format=3 uid="uid://doasoppn16sj5"]

[ext_resource type="Script" uid="uid://dvr4dfli4tbxn" path="res://battle/classes/dialogue_line.gd" id="1_eva7r"]
[ext_resource type="Texture2D" uid="uid://dtq0b7rfqcr5c" path="res://art/portraits/bank_demon_glass_on.png" id="2_gsd7p"]
[ext_resource type="Script" uid="uid://crsnq2fq76xma" path="res://battle/classes/dialogue_conversation.gd" id="2_m0sif"]
[ext_resource type="Texture2D" uid="uid://dvtwi74uuxjl3" path="res://art/portraits/bank_demon_glass_down.png" id="3_5acnn"]
[ext_resource type="Texture2D" uid="uid://85bxmm11fx8a" path="res://art/portraits/jackal_portrait.png" id="4_x3ae4"]
[ext_resource type="Texture2D" uid="uid://c0nwmag75d5b4" path="res://art/portraits/mel_portrait.png" id="5_r4r3h"]
[ext_resource type="Texture2D" uid="uid://ba4r0h2itoay6" path="res://art/portraits/daisy_portrait.png" id="6_gtnay"]

[sub_resource type="Resource" id="Resource_udjag"]
script = ExtResource("1_eva7r")
speaker_name = "Dover"
portrait = ExtResource("2_gsd7p")
text = "Hey! This is a private office space. You can't come in--"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_b1ku2"]
script = ExtResource("1_eva7r")
speaker_name = "Dover"
portrait = ExtResource("3_5acnn")
text = "Jackal? Is that you, man?"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_4tyc0"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "Guess my disguise can't hide me from the paparazzi. "
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_gsd7p"]
script = ExtResource("1_eva7r")
speaker_name = "Mel"
portrait = ExtResource("5_r4r3h")
text = "Should I be worried?"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_5acnn"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "That's usually a good idea, I've heard."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_x3ae4"]
script = ExtResource("1_eva7r")
speaker_name = "Mel"
portrait = ExtResource("5_r4r3h")
text = "Jackal..."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_r4r3h"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "Nah, just kidding! This guy's alright. Dover, meet the squad."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_gtnay"]
script = ExtResource("1_eva7r")
speaker_name = "Dover"
portrait = ExtResource("3_5acnn")
text = "Oh, you're running with a human now, eh Jackal?"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_2q3kw"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "Says the guy dressed up like a human banker."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_jq2n4"]
script = ExtResource("1_eva7r")
speaker_name = "Dover"
portrait = ExtResource("2_gsd7p")
text = "You like the fit? It's my disguise. I've been laying low, living the normal life."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_2fklg"]
script = ExtResource("1_eva7r")
speaker_name = "Dover"
portrait = ExtResource("2_gsd7p")
text = "No one here knows I'm a demon!"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_l718j"]
script = ExtResource("1_eva7r")
speaker_name = "Mel"
portrait = ExtResource("5_r4r3h")
text = "Was that supposed to be a whisper?"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_dqt8l"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "Dover, can you help us out, man? We're trying to get through the Scrapyards."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_sr27j"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "Looks like the way is locked down by someone though."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_4k11k"]
script = ExtResource("1_eva7r")
speaker_name = "Dover"
portrait = ExtResource("2_gsd7p")
text = "The Scrapyard? Hah!"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_uhcxu"]
script = ExtResource("1_eva7r")
speaker_name = "Dover"
portrait = ExtResource("3_5acnn")
text = "That's just Dave hiding out there, man! Got himself some muscle and holed up in there."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_t8hi5"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "Dave's here, too? Man, this place is becoming a demon hot spot."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_2xk8f"]
script = ExtResource("1_eva7r")
speaker_name = "Daisy"
portrait = ExtResource("6_gtnay")
text = "Um... Dave doesn't seem like a very demonic name."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_l0kmd"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "Daisy doesn't seem like a very robotic name. Yet there you are!"
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

[sub_resource type="Resource" id="Resource_jpw6a"]
script = ExtResource("1_eva7r")
speaker_name = "Jackal"
portrait = ExtResource("4_x3ae4")
text = "Anyways, now that I know this is Dave, I know what to do. Let's head back to the Scrapyard now."
metadata/_custom_type_script = "uid://dvr4dfli4tbxn"

